# Live CLOB trading — copy to .env and fill credentials.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/polybot

POLY_ENABLE_LIVE_TRADING=1

POLY_STRATEGY_PROFILE=balanced

POLY_SPREAD_PCT=0.04
POLY_MIN_EDGE=0.015
POLY_ORDER_SIZE=30
POLY_MAX_POSITION=300
POLY_QUOTE_REFRESH_SEC=30
POLY_MARKETS_WATCHED=8
POLY_MIN_MARKET_LIQUIDITY=1000
POLY_MAX_DAILY_LOSS=100
POLY_MAX_OPEN_ORDERS=25
POLY_CANCEL_BEFORE_REQUOTE=1

POLY_PRIVATE_KEY=0x_your_polygon_wallet_private_key
POLY_API_KEY=your_clob_api_key
POLY_API_SECRET=your_clob_api_secret
POLY_PASSPHRASE=your_clob_passphrase
