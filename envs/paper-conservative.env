# Paper profile (conservative / lower risk)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/polybot

POLY_FORCE_PAPER=1
POLY_EXECUTION_MODE=paper
POLY_ENABLE_LIVE_TRADING=0
POLY_PAPER_INITIAL_BALANCE=500

# Conservative preset from market_maker.py
POLY_STRATEGY_PROFILE=conservative

# Optional safety tightening
POLY_MAX_DAILY_LOSS=100
POLY_MAX_OPEN_ORDERS=25
POLY_MARKETS_WATCHED=8
POLY_ORDER_SIZE=25

POLY_MIN_ORDER_SHARES=5
POLY_CANCEL_BEFORE_REQUOTE=1
POLY_BTC_REFERENCE_REFRESH_SEC=120
POLY_DASHBOARD_THREADS=12
