## PolyBot — live CLOB trading only (paper simulation removed)
## Copy to .env:  cp env.example .env
## Or:  cp envs/live-template.env .env

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/polybot

# Must be 1 for market_maker.py to start (real Polymarket orders)
POLY_ENABLE_LIVE_TRADING=1

POLY_STRATEGY_PROFILE=balanced

POLY_SPREAD_PCT=0.04
POLY_MIN_EDGE=0.015
POLY_ORDER_SIZE=50
POLY_MAX_POSITION=500
POLY_QUOTE_REFRESH_SEC=30
POLY_MARKETS_WATCHED=10
POLY_MARKETS_FETCH_LIMIT=1000
POLY_MIN_MARKET_LIQUIDITY=1000
POLY_MAX_DAILY_LOSS=200
POLY_MAX_OPEN_ORDERS=40
POLY_INVENTORY_SOFT_LIMIT_PCT=0.60
POLY_INVENTORY_HARD_LIMIT_PCT=0.90
POLY_INVENTORY_SKEW_PCT=0.01
POLY_PASSIVE_BUFFER_TICKS=1
POLY_MIN_MID_DISTANCE_PCT=0.005
POLY_MAX_MID_DISTANCE_PCT=0.30
POLY_EXEC_QHIT_GOOD=0.45
POLY_EXEC_QHIT_WARN=0.20
POLY_EXEC_ACK_GOOD=0.75
POLY_EXEC_ACK_WARN=0.50
POLY_EXEC_FILL_GOOD=0.30
POLY_EXEC_FILL_WARN=0.12
POLY_EXEC_SCORE_W_QHIT=0.35
POLY_EXEC_SCORE_W_ACK=0.40
POLY_EXEC_SCORE_W_FILL=0.25
POLY_EXEC_SCORE_GOOD=55
POLY_EXEC_SCORE_WARN=35

POLY_MIN_ORDER_SHARES=5
POLY_MAX_ORDERS_PER_CYCLE=20
POLY_CANCEL_BEFORE_REQUOTE=1
POLY_BTC_REFERENCE_REFRESH_SEC=120
POLY_ANCHOR_EVENT_HAZARD_PER_DAY=0.001
POLY_GTA_RELEASE_HAZARD_PER_DAY=0.0002

POLY_DASHBOARD_THREADS=12
POLY_DASHBOARD_DATA_SOURCE=auto
POLY_DASHBOARD_LOG_LINES=120

# Polygon wallet + Polymarket CLOB. Either POLY_* or POLYMARKET_* names work.
# Default: derive CLOB API key/secret/passphrase from the wallet (fixes 401 Invalid api key when manual keys are wrong).
# Set to 0 only if you paste matching API credentials from Polymarket for this wallet.
# POLY_CLOB_AUTO_DERIVE_API_CREDS=1
POLY_PRIVATE_KEY=
# Optional when POLY_CLOB_AUTO_DERIVE_API_CREDS=1 (default):
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=
# POLYMARKET_PRIVATE_KEY=
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=

# Optional: if CLOB balance on the dashboard is wrong or zero, match your Polymarket wallet type
# (EOA=0, email/Magic=1, proxy=2 — see Polymarket CLOB docs). Same host as the bot:
# POLY_CLOB_SIGNATURE_TYPE=0
# POLY_CLOB_FUNDER=

# If POST /order returns HTTP 403 "Trading restricted in your region", Polymarket geoblocks that IP;
# use an allowed region/VPN or host per https://docs.polymarket.com/developers/CLOB/geoblock (not fixable in this repo).

# Checklist: pip install -r requirements.txt && pip install py-clob-client
# Fund wallet (USDC + MATIC). Then POLY_ENABLE_LIVE_TRADING=1 and run:
#   python market_maker.py
#   python server.py
