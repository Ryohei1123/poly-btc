## PolyBot environment template
## Copy to .env and adjust values:
##   cp env.example .env

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/polybot

# Force paper trading mode (recommended default)
POLY_FORCE_PAPER=1

# execution mode: paper | live
POLY_EXECUTION_MODE=paper

# hard safety switch - must be 1 to allow real live orders
POLY_ENABLE_LIVE_TRADING=0

# Starting paper balance in USDC
POLY_PAPER_INITIAL_BALANCE=500

# Quote notional controls
POLY_MIN_ORDER_SHARES=5
POLY_MAX_ORDERS_PER_CYCLE=20

# Dashboard concurrency for Waitress (helps avoid queue warnings)
POLY_DASHBOARD_THREADS=12

# Optional live trading credentials (leave empty for paper mode)
POLY_PRIVATE_KEY=
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

